# ── Django Core ───────────────────────────────────────────────────
# Generate a new secret key with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=oixtrcvsil)%(^^3bq%hq=iw4vzoqrkq3iitnvj#nmn*a-o^1x

# Set to False in production
DJANGO_DEBUG=True

# Comma-separated list of allowed hosts (no spaces)
# Example for production: ALLOWED_HOSTS=abicarehospital.com,www.abicarehospital.com
ALLOWED_HOSTS=localhost,127.0.0.1,ehr.abicarehospital.com


# ── Database ─────────────────────────────────────────────────────
# Options:
#   django.db.backends.postgresql   ← recommended
#   django.db.backends.mysql
#   django.db.backends.sqlite3      ← development only (no DB_* vars needed)

DB_ENGINE=django.db.backends.postgresql
DB_NAME=railway
DB_USER=postgres
DB_PASSWORD=NrEuWaRYOmsUxguwkaTcFUpEnktOEJRc
DB_HOST=yamabiko.proxy.rlwy.net
DB_PORT=14759
# For MySQL, change DB_PORT=3306
postgresql://postgres:NrEuWaRYOmsUxguwkaTcFUpEnktOEJRc@yamabiko.proxy.rlwy.net:14759/railway

# ── Email (for password resets, notifications) ────────────────────
# Development: leave EMAIL_BACKEND as console (prints to terminal)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# Production: switch to SMTP
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

